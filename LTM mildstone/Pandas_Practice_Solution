import pandas as pd
# Task 1
def load_and_clean_inventory(inventory_path):
    inventory_df = pd.read_csv(inventory_path)
    inventory_df = inventory_df.drop_duplicates()
    inventory_df['Stock'] = inventory_df['Stock'].fillna(0)
    inventory_df['Stock'] = inventory_df['Stock'].astype(int)
    return inventory_df

# Task 2
def low_stock_products(inventory_df, threshold):
    return inventory_df[inventory_df['Stock'] < threshold]

# Task 3
def calculate_inventory_value(inventory_df):
    inventory_df['InventoryValue'] = (inventory_df['Stock'] * inventory_df['Price'])
    return inventory_df

# Task 4
def category_summary(inventory_df):
    summary = inventory_df.groupby('Category').agg(
        TotalStock=('Stock', 'sum'),
        AveragePrice=('Price', 'mean'),
        TotalInventoryValue=('InventoryValue', 'sum')
    )
    return summary

# Task 5
def merge_supplier_details(inventory_df, supplier_df):
    merged_df = pd.merge(
        inventory_df,
        supplier_df,
        on='SupplierID'
    )
    return merged_df

# Task 6
def top_inventory_products(inventory_df, n):
    return inventory_df.nlargest(n,'InventoryValue' )



